{
  "name": "@buddy/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/app.tsx",
    "./app": "./src/app.tsx",
    "./context/platform": "./src/context/platform.tsx",
    "./context/server": "./src/context/server.tsx"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "preview": "vite preview",
    "test": "bun test --preload ./happydom.ts test",
    "test:parity": "bun test --preload ./happydom.ts test/parity"
  },
  "dependencies": {
    "@buddy/sdk": "workspace:*",
    "@buddy/ui": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-router": "^1.0.0",
    "@tanstack/router-devtools": "^1.0.0",
    "dompurify": "^3.3.1",
    "katex": "^0.16.22",
    "marked": "^17.0.1",
    "marked-katex-extension": "^5.1.5",
    "marked-shiki": "^1.2.1",
    "monaco-editor": "^0.52.2",
    "morphdom": "^2.7.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shiki": "^3.20.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.0.11",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/router-plugin": "^1.0.0",
    "@types/node": "22.13.9",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "7.1.4"
  }
}
