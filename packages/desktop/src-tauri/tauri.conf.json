{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Buddy Dev",
  "identifier": "dev.buddy.desktop",
  "mainBinaryName": "Buddy",
  "version": "../package.json",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "icon": [
      "icons/dev/32x32.png",
      "icons/dev/128x128.png",
      "icons/dev/128x128@2x.png",
      "icons/dev/icon.icns",
      "icons/dev/icon.ico"
    ],
    "externalBin": ["sidecars/buddy-backend"],
    "resources": ["resources/migrations"]
  }
}
