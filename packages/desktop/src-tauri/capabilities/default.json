{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:allow-is-focused",
    "dialog:default",
    "notification:default",
    "os:default",
    "process:default",
    "shell:default",
    "store:default",
    "window-state:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*" },
        { "url": "https://*" },
        { "url": "http://*:*/*" }
      ]
    }
  ]
}
