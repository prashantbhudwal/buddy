{
  "name": "@buddy/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "bun --env-file=../../.env run src/index.ts",
    "test": "bun test --preload ./test/preload.ts test",
    "test:parity": "bun test --preload ./test/preload.ts test/parity",
    "format": "echo 'Formatting code...' && bunx prettier --write src/*.ts src/**/*.ts",
    "db": "bun drizzle-kit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "2.0.62",
    "@buddy/opencode-adapter": "workspace:*",
    "@hono/standard-validator": "^0.2.2",
    "ai": "5.0.124",
    "drizzle-orm": "1.0.0-beta.12-a5629fb",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.0",
    "hono-openapi": "1.1.2",
    "jsonc-parser": "^3.3.1",
    "remeda": "^2.33.0",
    "turndown": "^7.2.2",
    "ulid": "^3.0.1",
    "xdg-basedir": "5.1.0",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@types/turndown": "^5.0.5",
    "@types/bun": "latest",
    "drizzle-kit": "1.0.0-beta.12-a5629fb",
    "typescript": "^5.0.0"
  }
}
