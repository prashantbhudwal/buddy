{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@buddy/opencode-adapter": ["./packages/opencode-adapter/src/index.ts"],
      "@buddy/opencode-adapter/*": ["./packages/opencode-adapter/src/*"],
      "@/*": ["./vendor/opencode-core/src/*"],
      "@tui/*": ["./vendor/opencode-core/src/cli/cmd/tui/*"],
      "@opencode-core/*": ["./vendor/opencode-core/src/*"]
    }
  }
}
